## Backend production env example (DO NOT commit real secrets)
# Replace values with your production DB, secret and allowed origin(s).
# If ALLOWED_ORIGIN or ALLOWED_ORIGINS contains "voltwheel", both voltwheelsin.com and voltwheelsind.com are allowed.
DATABASE_URL=postgres://<USER>:<PASSWORD>@<HOST>:5432/<DBNAME>?sslmode=require
JWT_SECRET=replace_with_strong_random_secret
ALLOWED_ORIGIN=https://voltwheelsind.com
# Optional: comma-separated list for multiple frontend origins
# ALLOWED_ORIGINS=https://voltwheelsind.com,https://voltwheelsin.com
NODE_ENV=production
SENDGRID_API_KEY=
SENDGRID_FROM=no-reply@example.com

