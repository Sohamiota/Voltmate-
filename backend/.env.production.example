# ─── Backend production environment variables ────────────────────────────────
# Set these in your hosting dashboard (Render / Railway / etc.).
# NEVER commit this file with real values filled in.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://<USER>:<PASSWORD>@<HOST>:5432/<DBNAME>?sslmode=require

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_strong_random_secret

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=https://voltwheelsind.com
# Optional: comma-separated list for multiple frontend origins
# ALLOWED_ORIGINS=https://voltwheelsind.com,https://voltwheelsin.com

# ── YouTube proxy ─────────────────────────────────────────────────────────────
# Server-side key — restrict it in Google Cloud Console to:
#   API restrictions → YouTube Data API v3
#   Application restrictions → IP addresses (your Render instance IPs)
YOUTUBE_API_KEY=replace_with_youtube_api_key

# ── Email (optional) ──────────────────────────────────────────────────────────
# OTP codes are logged to server stdout on registration — no mail provider configured.

# ── Runtime ───────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production
# Increase the heap limit to avoid OOM crashes on free-tier instances:
NODE_OPTIONS=--max-old-space-size=400
