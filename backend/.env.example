# ─── Backend environment variables ───────────────────────────────────────────
# Copy this file to .env (never commit .env) and fill in real values.
# Generate JWT_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres@localhost:5432/postgres

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED — must be a strong random secret (64+ hex chars recommended).
# The server will refuse to start if this is missing.
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET

# ── CORS ──────────────────────────────────────────────────────────────────────
# Primary allowed origin for the frontend.
ALLOWED_ORIGIN=http://localhost:3000
# Optional: comma-separated list of additional allowed origins.
# ALLOWED_ORIGINS=https://voltwheelsind.com,https://voltwheelsin.com

# ── YouTube proxy ─────────────────────────────────────────────────────────────
# Server-side YouTube Data API v3 key. Create one at console.cloud.google.com.
# Restrict it to "API restrictions: YouTube Data API v3" only.
# This key is NEVER sent to the browser — all YouTube calls are proxied here.
YOUTUBE_API_KEY=REPLACE_WITH_YOUR_YOUTUBE_API_KEY

# ── Email (optional — not yet wired up) ──────────────────────────────────────
# SENDGRID_API_KEY=
# SENDGRID_FROM=no-reply@example.com

# ── Runtime ───────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
