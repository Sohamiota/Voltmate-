#
# Combined .gitignore (merged from HEAD and production)
#

# v0 runtime files (should only exist in preview, not in git)
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts

# Node
node_modules/
**/node_modules/
npm-debug.log*
yarn-error.log
pnpm-debug.log*
.pnpm-store/

# Environment — never commit secrets
.env
.env.local
.env.development
.env.production
.env.test
.env.*.local
/*.env
**/.env
!**/.env.example
!**/.env.*.example

# Next.js / build output
.next/
**/.next/
dist/
**/dist/
build/
out/

# TypeScript
*.tsbuildinfo

# Tooling caches
.eslintcache
.turbo/
.cache/
eslint-report.json

# Uploaded leave proof documents & billing archives
backend/uploads/

# Generated report exports (do not commit)
backend/*.csv
backend/*.xlsx
docs/CRM_User_Manual_Data_Entry.pdf

# Logs
logs/
*.log
debug.log*

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor (local only — share rules via .cursor/rules if needed)
.vscode/
.idea/
*.swp
*.swo
*~

# Cursor — keep `.cursor/rules/` shareable; ignore other local Cursor metadata
.cursor/*
!.cursor/rules/
!.cursor/rules/**

# Docker
docker-compose.override.yml
/voltmate-db-data/

# Test / E2E output (not source)
coverage/
**/coverage/
**/test-results/
**/playwright-report/
**/cypress/videos/
**/cypress/screenshots/

# ── Sample / demo code (not the production Voltmate app) ─────────────────────
frontend-samples/

# ── Local-only test / debug scripts ───────────────────────────────────────────
backend/check_pass.js

# Backend ops / admin scripts (local DB tools — do not commit)
backend/scripts/
backend-node/scripts/

# ── Root-level junk files ───────────────────────────────────────────────────
,
commit_msg.txt
render_db.json

# Local SQL seeds (may contain credentials)
backend/seed_admin.sql

# Credential / test-payload files — must never be committed
tmp/
tmp_login.json
tmp_register.json
**/tmp_login.json
**/tmp_register.json

# Keys / local DB files
*.sqlite
*.pem
*.key

# Deploy platform local config
/.vercel
**/.vercel

# Legacy / unused local folders
voltmate-back/
