#
# Combined .gitignore (merged from HEAD and production)
#

# v0 runtime files (should only exist in preview, not in git)
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts

# Node
node_modules/
npm-debug.log*
yarn-error.log

# Environment
.env
.env.local
.env.*.local
/*.env

# Next.js / build
.next/
dist/
build/
out/

# TypeScript
*.tsbuildinfo

# Tooling caches
.eslintcache
.turbo/

# Uploaded leave proof documents
backend/uploads/

# Logs
logs/
*.log
debug.log*

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor
.vscode/
.idea/

# Cursor — keep `.cursor/rules/` shareable; ignore other local Cursor metadata
.cursor/*
!.cursor/rules/
!.cursor/rules/**

# Docker
docker-compose.override.yml
/voltmate-db-data/

# Misc
.cache/
coverage/

# ── Sample / demo code (not the production Voltmate app) ─────────────────────
frontend-samples/

# ── Local-only test / debug scripts (DB checks, one-off API calls, hash tools) ─
backend/check_pass.js
backend/scripts/test_db.js
backend/scripts/clear-test-data.ts
backend/scripts/debug_stats.js
backend/scripts/call_stats.js
backend/scripts/generate_hash.js
backend/scripts/gen-hash-once.js

# ── One-off / personal ops scripts (date-specific reports, one-time fixes) ─────
backend/scripts/attendance-report.js
backend/scripts/fix-rahul.js
backend/scripts/sanjoy-absent.js
backend/scripts/sanjoy-full.js
backend/scripts/update-network.js
backend/scripts/utpal-absent.js
backend/scripts/_check-statuses.js
backend/scripts/active-leads-report.js
backend/scripts/demo-not-scheduled-report.js
backend/scripts/export-leads-last-month.mjs
backend/scripts/location-leads-report.mjs

# ── Root-level junk files ────────────────────────────────────────────────────────
,
commit_msg.txt
render_db.json

# ── Sample seed data & SQL (keep migrate + seed-vehicles.js in repo; data optional)
backend/scripts/seed-vehicles-data.json
backend/seed_admin.sql

backend-node/scripts/generate_hash.js
backend-node/scripts/insert_user.js

# ── Test runner output (no source)
**/test-results/
**/playwright-report/
**/cypress/videos/
**/cypress/screenshots/

# Additional ignores
tmp/
*.sqlite
*.pem
*.key
/.vercel

# Credential / test-payload files — must never be committed
tmp_login.json
tmp_register.json
**/tmp_login.json
**/tmp_register.json
backend/node_modules/
frontend/node_modules/
Voltmate-/node_modules/
voltmate-back/
