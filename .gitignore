# =============================================================================
# VoltWheels EMS — production .gitignore
# Keeps secrets, local ops tooling, uploads, and build artifacts out of git.
# Safe to commit: source, migrations, .env.example, public assets, lockfiles.
# =============================================================================

# ── Environment & secrets (NEVER commit) ─────────────────────────────────────
.env
.env.*
!.env.example
!**/.env.example
!**/.env.*.example
*.local

# Service accounts / API keys on disk
**/credentials.json
**/credentials*.json
**/*service-account*.json
**/*service_account*.json
**/*-sa.json
**/google-credentials.json
**/firebase-adminsdk*.json

# Keys & certs
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der

# ── Node / package managers ──────────────────────────────────────────────────
node_modules/
**/node_modules/
.npm/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── TypeScript / build output ────────────────────────────────────────────────
dist/
**/dist/
build/
**/build/
out/
**/.next/
.next/
*.tsbuildinfo

# ── Tooling caches ───────────────────────────────────────────────────────────
.eslintcache
.turbo/
.cache/
.parcel-cache/
eslint-report.json

# ── Next.js / Vercel / Render local deploy metadata ───────────────────────────
.vercel/
**/.vercel/
.render/

# ── User uploads & generated runtime files ───────────────────────────────────
backend/uploads/
backend-node/uploads/
**/uploads/
**/leave-proofs/

# ── Exports & reports (generated locally — not source) ────────────────────────
**/*.csv
**/*.xlsx
**/*.xls
!**/public/**
backend/*.csv
backend/*.xlsx

# ── DB dumps, seeds with credentials, local DB files ─────────────────────────
*.sql.backup
*.dump
*.sqlite
*.sqlite3
*.sqlite-journal
backup/
**/backup/
backend/seed_admin.sql
render_db.json
voltmate-db-data/
/voltmate-db-data/

# ── Local ops / admin / scraper scripts (run on machine only) ────────────────
backend/scripts/
backend-node/scripts/
backend/check_pass.js
Voltmate-/scripts/

# ── Credential & debug payloads ──────────────────────────────────────────────
tmp/
**/tmp/
tmp_login.json
tmp_register.json
**/tmp_login.json
**/tmp_register.json
commit_msg.txt

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
**/logs/
*.log
debug.log*
firebase-debug.log
firestore-debug.log
ui-debug.log

# ── Test / coverage / E2E artifacts ──────────────────────────────────────────
coverage/
**/coverage/
*.lcov
test-results/
**/test-results/
playwright-report/
**/playwright-report/
cypress/videos/
cypress/screenshots/

# ── OS junk ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
nul
NUL
,

# ── Editor / IDE (share team rules via .cursor/rules if needed) ───────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.code-workspace

# Cursor — keep rules shareable; ignore local agent metadata
.cursor/*
!.cursor/rules/
!.cursor/rules/**

# ── Docker local overrides & volumes ─────────────────────────────────────────
docker-compose.override.yml
docker-compose.override.yaml

# ── Archives & local export folders ──────────────────────────────────────────
**/exports/
*.zip
*.7z
*.tar
*.tar.gz
*.tgz
*.rar

# ── Generated docs (build locally) ─────────────────────────────────────────────
docs/CRM_User_Manual_Data_Entry.pdf

# ── v0 preview runtime (not production source) ─────────────────────────────────
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts

# ── Non-production / legacy / sample trees ───────────────────────────────────
frontend-samples/
voltmate-back/
