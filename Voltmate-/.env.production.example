# ─── Frontend (Next.js) production environment variables ─────────────────────
# Set these in Vercel / your hosting dashboard.
# NEVER commit this file with real values filled in.
#
# IMPORTANT: Only variables prefixed NEXT_PUBLIC_ are embedded in the browser
# bundle. Do NOT put secrets in NEXT_PUBLIC_ variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API base URL (no trailing slash, no /api/v1) ─────────────────────
NEXT_PUBLIC_API_URL=https://voltmate.onrender.com

# NOTE: The YouTube API key is NO LONGER required here.
# YouTube calls are now proxied through the backend — the key lives in
# backend/.env as YOUTUBE_API_KEY and is never sent to the browser.
