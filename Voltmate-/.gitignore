# Voltmate frontend — extends repo root .gitignore
# (Git merges rules from parent directories automatically.)

# Build & deps (when working inside Voltmate-/ only)
node_modules/
.next/
out/
dist/
*.tsbuildinfo

# Env — examples are allowed
.env
.env.*
!.env.example
!.env.*.example

# Deploy & caches
.vercel/
.eslintcache
.turbo/
.cache/

# Local asset scrapers (not shipped to Vercel)
scripts/

# Test output
coverage/
test-results/
playwright-report/

# OS
.DS_Store
Thumbs.db
